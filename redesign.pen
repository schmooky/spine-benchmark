              "fontFamily": "Fraunces",
              "fontSize": 24,
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "vn4UX",
              "name": "mxSub",
              "fill": "$ed-text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Derived from current code implementation. Each row summarizes what users see, what metrics are shown, and which controls are active.",
              "lineHeight": 1.4,
              "fontFamily": "Inter",
              "fontSize": 12,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "tM60H",
          "name": "mxBody",
          "width": "fill_container",
          "height": "fill_container",
          "fill": "$ed-surface-warm",
          "stroke": {
            "align": "inside",
            "thickness": 1,
            "fill": "$ed-border"
          },
          "layout": "vertical",
          "gap": 8,
          "padding": 14,
          "children": [
            {
              "type": "text",
              "id": "aETTZ",
              "name": "r1",
              "fill": "$ed-text",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "/tools/benchmark → Metrics: RI, CI, Bones, Anims. Sections: Summary, Mesh, Clipping, Blend, Physics, Skeleton Tree. Canvas overlays: FPS/DC/TX + pixel footprint.",
              "lineHeight": 1.35,
              "fontFamily": "Inter",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "f9yCq",
              "name": "r2",
              "fill": "$ed-text",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "/tools/mesh-optimizer → Metrics: total meshes, vertices, triangles, weighted. Mesh table + selected mesh preview + optimization report + Save&Load Optimized.",
              "lineHeight": 1.35,
              "fontFamily": "Inter",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "Su6XD",
              "name": "r3",
              "fill": "$ed-text",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "/tools/physics-baker → Metrics by type: IK/Transform/Path/Physics. Constraint table, row-click debug overlay, bake report fields, Save&Load Baked.",
              "lineHeight": 1.35,
              "fontFamily": "Inter",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "aZkUO",
              "name": "r4",
              "fill": "$ed-text",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "/tools/draw-call-inspector → Metrics: draw calls, page breaks, blend breaks. Hide Invisible toggle + slot table with selected/invisible/break row states.",
              "lineHeight": 1.35,
              "fontFamily": "Inter",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "B5Xjv",
              "name": "r5",
              "fill": "$ed-text",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "/tools/atlas-repack → Metrics: pages, regions, draw calls, page breaks. Atlas page cards + scaled region overlays + problematic region emphasis.",
              "lineHeight": 1.35,
              "fontFamily": "Inter",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "jgEIB",
              "name": "r6",
              "fill": "$ed-text",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "/tools/comparison → Two pane A/B compare. Shared playback+loop+animation controls. Animation list uses intersection when both assets loaded. Shared zoom/pan camera.",
              "lineHeight": 1.35,
              "fontFamily": "Inter",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "XOw7b",
              "name": "r7",
              "fill": "$ed-text",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "/tools/animation-heatmap → Analyze All button, per-animation expand panels, DC/TX/BB chart with hover tooltip and click-to-pin frame detail table.",
              "lineHeight": 1.35,
              "fontFamily": "Inter",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "w7n32",
              "name": "r8",
              "fill": "$ed-text",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "/assets → Asset cards show name/count/size/description and inline Load/Delete. Full import modal includes skeleton/atlas/texture validation and missing-atlas-image checks.",
              "lineHeight": 1.35,
              "fontFamily": "Inter",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "Nb53F",
              "name": "r9",
              "fill": "$ed-text",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "/documentation and /partners → simple external-link lists (no runtime metrics, no playback controls).",
              "lineHeight": 1.35,
              "fontFamily": "Inter",
              "fontSize": 12,
              "fontWeight": "normal"
            }
          ]
        }
      ]
    },
