{
  "name": "spine-benchmark-monorepo",
  "private": true,
  "version": "1.2.0",
  "description": "Spine Benchmark monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @spine-benchmark/site",
    "build": "npm run build --workspace @spine-benchmark/site",
    "build:site": "npm run build --workspace @spine-benchmark/site",
    "build:metrics-factors": "npm run build --workspace @spine-benchmark/metrics-factors",
    "build:metrics-scoring": "npm run build --workspace @spine-benchmark/metrics-scoring",
    "build:metrics-sampling": "npm run build --workspace @spine-benchmark/metrics-sampling",
    "build:metrics-analyzers": "npm run build --workspace @spine-benchmark/metrics-analyzers",
    "build:metrics-pipeline": "npm run build --workspace @spine-benchmark/metrics-pipeline",
    "build:metrics-reporting": "npm run build --workspace @spine-benchmark/metrics-reporting",
    "build:metrics": "npm run build --workspace @spine-benchmark/metrics",
    "build:spinefolio": "npm run build --workspace @spine-benchmark/spinefolio",
    "build:asset-store": "npm run build --workspace @spine-benchmark/asset-store",
    "build:mesh-tools": "npm run build --workspace @spine-benchmark/mesh-tools",
    "build:constraint-tools": "npm run build --workspace @spine-benchmark/constraint-tools",
    "build:drawcall-tools": "npm run build --workspace @spine-benchmark/drawcall-tools",
    "build:render-tools": "npm run build --workspace @spine-benchmark/render-tools",
    "build:spine-loader": "npm run build --workspace @spine-benchmark/spine-loader",
    "build:file-tools": "npm run build --workspace @spine-benchmark/file-tools",
    "build:workbench-core": "npm run build --workspace @spine-benchmark/workbench-core",
    "demo:spinefolio": "npm run demo --workspace @spine-benchmark/spinefolio --",
    "publish:spinefolio": "npm publish --workspace @spine-benchmark/spinefolio --access public",
    "preview": "npm run preview --workspace @spine-benchmark/site",
    "check:i18n": "npm run check:i18n --workspace @spine-benchmark/site",
    "sync:locales": "npm run sync:locales --workspace @spine-benchmark/site",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.2.4"
  }
}
