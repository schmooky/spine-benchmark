{
  "name": "@spine-benchmark/file-tools",
  "version": "0.1.0",
  "description": "File processing helpers for Spine Benchmark app workflows",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@spine-benchmark/asset-store": "file:../asset-store",
    "@spine-benchmark/spine-loader": "file:../spine-loader"
  },
  "peerDependencies": {
    "pixi.js": "^8.16.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
